# Application
SECRET_KEY=change-me-to-a-long-random-string
APP_NAME=Broadcast Messenger
APP_URL=http://localhost:8000
PORT=8000

# Database — use Neon Postgres (free) for permanent storage (templates, automation, contacts).
# Sign up: https://neon.tech → Create project → Connect → copy URI (include ?sslmode=require)
#
# Production / Render (required):
# DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require
#
# Local dev — SQLite (easy start, data not shared with production):
DATABASE_URL=sqlite+aiosqlite:///./broadcast_messenger.db
#
# Local dev — same Neon DB as production (recommended if testing persistence):
# DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Facebook Developer App — MUST be real values from developers.facebook.com
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_API_VERSION=v21.0
